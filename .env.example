# ===========================================================================
# Valpovački AI gradski informator — konfiguracija okoline
# Kopirajte u .env.local (lokalno) odnosno unesite u Vercel → Settings →
# Environment Variables (produkcija). Tajne NIKADA ne commitajte u repozitorij.
# ===========================================================================

# --- Claude (generiranje odgovora) -----------------------------------------
# API ključ: https://platform.claude.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Model za generiranje. VAŽNO: model "claude-3.5-sonnet" iz specifikacije
# (puni ID claude-3-5-sonnet-20241022) POVUČEN je iz upotrebe 28. 10. 2025.
# i API vraća 404. Službena zamjena je claude-sonnet-4-6 (zadano ovdje).
# Po želji promijenite npr. u claude-haiku-4-5 (brže/jeftinije) ili
# claude-opus-4-8 (najsposobniji).
CLAUDE_MODEL=claude-sonnet-4-6

# Maksimalan broj izlaznih tokena po odgovoru
CLAUDE_MAX_TOKENS=1024

# --- Embeddingi (vektorizacija) ---------------------------------------------
# VAŽNO: Anthropic NE nudi API za embeddinge — model "claude-embed-v1" iz
# specifikacije ne postoji. Podržani pružatelji: "openai" (zadano) ili
# "voyage" (Voyage AI, pružatelj kojeg Anthropic službeno preporučuje).
EMBEDDING_PROVIDER=openai

# openai:  text-embedding-3-small (1536 dim) ili text-embedding-3-large (3072)
# voyage:  voyage-3 (1024 dim)
EMBEDDING_MODEL=text-embedding-3-small

# Dimenzija vektora — MORA odgovarati stupcu vector(DIM) u supabase/schema.sql!
# Promijenite li model/dimenziju, ažurirajte shemu i ponovno indeksirajte.
EMBEDDING_DIM=1536

# Ključ pružatelja embeddinga (ovisno o EMBEDDING_PROVIDER)
OPENAI_API_KEY=sk-...
VOYAGE_API_KEY=

# --- Supabase ----------------------------------------------------------------
# Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# Service-role ključ — koristi se ISKLJUČIVO na poslužitelju (ingest, RPC)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon ključ (javni; trenutačno nije potreban na klijentu, rezerviran za budućnost)
SUPABASE_ANON_KEY=eyJ...

# --- RAG parametri -------------------------------------------------------------
# Broj isječaka koji se dohvaća vektorskim pretraživanjem
RAG_TOP_K=8
# Prag kosinusne sličnosti (0–1); isječci ispod praga se odbacuju
RAG_SCORE_THRESHOLD=0.35
# Uključuje leksički (Postgres FTS) rezervni kanal kad vektorsko pretraživanje
# ne vrati dovoljno rezultata (1 = uključeno, 0 = isključeno)
RAG_FTS_FALLBACK=1
# Maksimalan proračun znakova za kontekst koji se šalje modelu (~4 znaka ≈ 1 token)
RAG_CONTEXT_CHAR_BUDGET=12000

# --- Ingestija -----------------------------------------------------------------
# Tajna kojom Vercel Cron (i ručni pozivi) autoriziraju /api/ingest.
# Generirajte npr.: openssl rand -hex 32
VERCEL_CRON_SECRET=

# Dopuštene domene izvora (zarezom odvojeno). Crawler NIKADA ne izlazi izvan
# ovog popisa. Primjer: gradska uprava + povezane ustanove.
ALLOWED_HOSTS=valpovo.hr,www.valpovo.hr,gradska-knjiznica-valpovo.hr,djecji-vrtic-maza-valpovo.hr

# Početne točke indeksiranja: sitemap(i) i/ili pojedinačni URL-ovi (zarezom odvojeno)
SITEMAP_URLS=https://valpovo.hr/sitemap.xml
SEED_URLS=https://valpovo.hr/

# Uzorci za PRESKAKANJE bezvrijednih URL-ova (zarezom odvojeno). Provjeravaju se
# kao podniz unutar punog URL-a (case-insensitive); uzorak s prefiksom "re:" je
# regex. PDF se NIKADA ne isključuje. Ako je nepostavljeno, koristi se ugrađeni popis
# (WP arhive/feedovi, galerije/listanja, STARE datumske arhive vijesti <=2024., te
# slike/dokumenti/arhive/mediji). Cilj: ~1500–2500 kvalitetnih stranica.
# Provjeri broj prije ingestije:  npm run ingest -- --dry-run   (analiza: --analyze)
EXCLUDE_URL_PATTERNS=/tag/,/page/,/author/,/category/,/feed,/wp-json,?replytocom,/attachment/,/rl_gallery/,/events/,re:/(?:19\d\d|20[01]\d|202[0-4])/,.jpg,.png,.zip,.doc

# Uzorci za PRESKAKANJE cijelih pod-sitemapova (zarezom odvojeno; podniz pune sitemap
# adrese). Tako se izbacuju galerije/taksonomije i, host-ciljano, "post" sitemap čije
# objave nemaju datum u URL-u (npr. ss-valpovo.hr/post-sitemap). Vidi stablo sitemapova:
# npm run ingest -- --analyze
EXCLUDE_SITEMAP_PATTERNS=rl_gallery,category-sitemap,author-sitemap,tag-sitemap,ss-valpovo.hr/wp-sitemap-posts-post

# Parametri chunkinga (u "tokenima"; interno ~4 znaka po tokenu)
MAX_CHUNK_TOKENS=300
CHUNK_OVERLAP=50

# Stanka između dohvaćanja dvaju URL-ova (ms) — pristojan rate-limit prema izvorima
CRAWL_DELAY_MS=1000
# Maksimalan broj URL-ova po jednom pokretanju ingestije (zaštita trajanja funkcije).
# Dokumenti se obrađuju "najstarije provjereni prvi" (sort po fetched_at uzlazno),
# pa se kroz uzastopne tjedne runde rotacijski obiđe cijeli korpus i kad je korpus
# veći od ovog limita. Postavi ga blizu veličini korpusa (vidi --dry-run) ako želiš
# pokriti sve u jednoj rundi i koliko dopušta trajanje funkcije.
INGEST_MAX_URLS=200

# --- Općenito --------------------------------------------------------------------
LANG=hr
