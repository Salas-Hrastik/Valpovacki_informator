# ===========================================================================
# Valpovački AI gradski informator — konfiguracija okoline
# Kopirajte u .env.local (lokalno) odnosno unesite u Vercel → Settings →
# Environment Variables (produkcija). Tajne NIKADA ne commitajte u repozitorij.
# ===========================================================================

# --- Claude (generiranje odgovora) -----------------------------------------
# API ključ: https://platform.claude.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Model za generiranje. VAŽNO: model "claude-3.5-sonnet" iz specifikacije
# (puni ID claude-3-5-sonnet-20241022) POVUČEN je iz upotrebe 28. 10. 2025.
# i API vraća 404. Službena zamjena je claude-sonnet-4-6 (zadano ovdje).
# Po želji promijenite npr. u claude-haiku-4-5 (brže/jeftinije) ili
# claude-opus-4-8 (najsposobniji).
CLAUDE_MODEL=claude-sonnet-4-6

# Maksimalan broj izlaznih tokena po odgovoru
CLAUDE_MAX_TOKENS=1024

# --- Embeddingi (vektorizacija) ---------------------------------------------
# VAŽNO: Anthropic NE nudi API za embeddinge — model "claude-embed-v1" iz
# specifikacije ne postoji. Podržani pružatelji: "openai" (zadano) ili
# "voyage" (Voyage AI, pružatelj kojeg Anthropic službeno preporučuje).
EMBEDDING_PROVIDER=openai

# openai:  text-embedding-3-small (1536 dim) ili text-embedding-3-large (3072)
# voyage:  voyage-3 (1024 dim)
EMBEDDING_MODEL=text-embedding-3-small

# Dimenzija vektora — MORA odgovarati stupcu vector(DIM) u supabase/schema.sql!
# Promijenite li model/dimenziju, ažurirajte shemu i ponovno indeksirajte.
EMBEDDING_DIM=1536

# Ključ pružatelja embeddinga (ovisno o EMBEDDING_PROVIDER)
OPENAI_API_KEY=sk-...
VOYAGE_API_KEY=

# --- Supabase ----------------------------------------------------------------
# Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# Service-role ključ — koristi se ISKLJUČIVO na poslužitelju (ingest, RPC)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon ključ (javni; trenutačno nije potreban na klijentu, rezerviran za budućnost)
SUPABASE_ANON_KEY=eyJ...

# --- RAG parametri -------------------------------------------------------------
# Zadane vrijednosti su u kodu (lib/config.ts). Postavi ENV samo ako želiš nadjačati.
# (Zakomentirano da slučajno ne pregaze dobre defaulte — kao i popisi izvora gore.)
#
# Broj isječaka koji se dohvaća (zadano 12):
#RAG_TOP_K=12
# Prag kosinusne sličnosti 0–1; niže = veći recall (zadano 0.30):
#RAG_SCORE_THRESHOLD=0.30
# Leksički (Postgres FTS) kanal — hibridni dohvat; ključan za činjenična pitanja
# i popise imena (1 = uključeno, 0 = isključeno; zadano uključeno):
#RAG_FTS_FALLBACK=1
# Proračun znakova za kontekst koji se šalje modelu (~4 znaka ≈ 1 token; zadano 12000):
#RAG_CONTEXT_CHAR_BUDGET=12000
# Reranking: brzi LLM (Haiku) presloži širi skup kandidata po relevantnosti — bira
# pravi dokument među mnogo sličnih (npr. zapisnika). 1 = uključeno (zadano), 0 = isključeno:
#RAG_RERANK=1
# Broj kandidata koji se rerankaju (zadano 24):
#RAG_RERANK_CANDIDATES=24
# Model za reranking (zadano claude-haiku-4-5 — brz/jeftin):
#RERANK_MODEL=claude-haiku-4-5

# --- Ingestija -----------------------------------------------------------------
# Tajna kojom Vercel Cron (i ručni pozivi) autoriziraju /api/ingest.
# Generirajte npr.: openssl rand -hex 32
VERCEL_CRON_SECRET=

# !! PAŽNJA — popisi izvora i filtra (ALLOWED_HOSTS, SITEMAP_URLS, SEED_URLS,
# EXCLUDE_URL_PATTERNS, EXCLUDE_SITEMAP_PATTERNS) imaju PUNE ugrađene vrijednosti u
# kodu (lib/config.ts): svih 11 valpovskih domena/sitemapova + cjeloviti filtar
# (~2050 stranica). Ako ih ovdje POSTAVIŠ, one NADJAČAVAJU (zamjenjuju) ugrađene —
# pa npr. "SITEMAP_URLS=https://valpovo.hr/sitemap.xml" suzi korpus SAMO na valpovo.hr.
# ZATO su namjerno ZAKOMENTIRANI: ostavi ih tako da koristiš pune defaulte iz koda.
# Odkomentiraj POJEDINI red samo ako ga svjesno želiš nadjačati (i navedi PUNI popis).
#
# Dopuštene domene izvora (crawler NIKADA ne izlazi izvan ovog popisa):
#ALLOWED_HOSTS=valpovo.hr,www.valpovo.hr,...
#
# Početne točke indeksiranja (sitemapovi i/ili pojedinačni URL-ovi):
#SITEMAP_URLS=https://valpovo.hr/sitemap.xml,https://oskatancic.hr/sitemap.xml,...
#SEED_URLS=https://valpovo.hr/
#
# Filtar bezvrijednih URL-ova (podniz; "re:" = regex; PDF se nikad ne isključuje):
#EXCLUDE_URL_PATTERNS=/tag/,/page/,/rl_gallery/,re:/(?:19\d\d|20[01]\d|202[0-4])/,.jpg,...
#
# Preskakanje cijelih pod-sitemapova (vidi stablo: npm run ingest -- --analyze):
#EXCLUDE_SITEMAP_PATTERNS=rl_gallery,ss-valpovo.hr/wp-sitemap-posts-post,...

# Parametri chunkinga (u "tokenima"; interno ~4 znaka po tokenu)
MAX_CHUNK_TOKENS=300
CHUNK_OVERLAP=50

# Stanka između dohvaćanja dvaju URL-ova (ms) — pristojan rate-limit prema izvorima
CRAWL_DELAY_MS=1000
# Maksimalan broj URL-ova po jednom pokretanju ingestije (zaštita trajanja funkcije).
# Dokumenti se obrađuju "najstarije provjereni prvi" (sort po fetched_at uzlazno),
# pa se kroz uzastopne tjedne runde rotacijski obiđe cijeli korpus i kad je korpus
# veći od ovog limita. Postavi ga blizu veličini korpusa (vidi --dry-run) ako želiš
# pokriti sve u jednoj rundi i koliko dopušta trajanje funkcije. Zadano u kodu: 2100
# (filtrirani korpus je ~2050 stranica). Na Vercel Hobby planu (60 s) jedna runda
# obradi tek dio pa rotacija dovrši korpus kroz nekoliko uzastopnih pokretanja.
INGEST_MAX_URLS=2100

# INGEST_FORCE=1 jednokratno preskače provjeru svježine (obradi SVE stranice ovaj
# prolaz) — korisno da se odmah otkriju i ingestiraju SVI PDF-ovi linkani sa stranica,
# bez čekanja da stranice "ostare". Nepromijenjene stranice se samo "dotaknu" (bez
# ponovnog embeddinga). Primjer:  INGEST_FORCE=1 npm run ingest
#INGEST_FORCE=1

# Zaštita PDF-koraka (da pokvaren/golem PDF ne zaglavi ingest):
# Timeout za parsiranje jednog PDF-a u ms (zadano 20000):
#PDF_PARSE_TIMEOUT_MS=20000
# Najveća dopuštena veličina PDF-a u bajtovima (zadano 26214400 = 25 MB):
#MAX_PDF_BYTES=26214400

# --- Općenito --------------------------------------------------------------------
LANG=hr

# Produkcijska adresa aplikacije (za kanonske/OG poveznice u <head>). Na Vercelu se
# inače koristi automatski VERCEL_URL; postavi za stabilnu/custom domenu.
NEXT_PUBLIC_SITE_URL=https://valpovacki-informator.vercel.app
