# ===========================================================================
# AI asistent ljudskih potencijala — konfiguracija okoline
# Kopirajte u .env.local (lokalno) odnosno unesite u Vercel → Settings →
# Environment Variables (produkcija). Tajne NIKADA ne commitajte u repozitorij.
# ===========================================================================

# --- Claude (generiranje odgovora) -----------------------------------------
# API ključ: https://platform.claude.com → API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Model za generiranje (zadano claude-sonnet-4-6). Po želji promijenite npr. u
# claude-haiku-4-5 (brže/jeftinije) ili claude-opus-4-8 (najsposobniji).
CLAUDE_MODEL=claude-sonnet-4-6

# Maksimalan broj izlaznih tokena po odgovoru (edukativni odgovori znaju biti duži)
CLAUDE_MAX_TOKENS=1536

# --- Embeddingi (vektorizacija) ---------------------------------------------
# VAŽNO: Anthropic NE nudi API za embeddinge. Podržani pružatelji:
# "openai" (zadano) ili "voyage" (Voyage AI, pružatelj kojeg Anthropic preporučuje).
EMBEDDING_PROVIDER=openai

# openai:  text-embedding-3-small (1536 dim) ili text-embedding-3-large (3072)
# voyage:  voyage-3 (1024 dim)
EMBEDDING_MODEL=text-embedding-3-small

# Dimenzija vektora — MORA odgovarati stupcu vector(DIM) u supabase/schema.sql!
# Promijenite li model/dimenziju, ažurirajte shemu i ponovno indeksirajte.
EMBEDDING_DIM=1536

# Ključ pružatelja embeddinga (ovisno o EMBEDDING_PROVIDER).
# OPENAI_API_KEY služi i za glasovne rute (/api/transcribe — Whisper, /api/speak — TTS).
OPENAI_API_KEY=sk-...
VOYAGE_API_KEY=

# --- Supabase ----------------------------------------------------------------
# Supabase → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
# Service-role ključ — koristi se ISKLJUČIVO na poslužitelju (ingest, RPC)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# Anon ključ (javni; trenutačno nije potreban na klijentu, rezerviran za budućnost)
SUPABASE_ANON_KEY=eyJ...

# --- Knjiga (korpus znanja) ----------------------------------------------------
# Naslov knjige (prikazuje se u citatima i promptu) i kratka interna oznaka.
#BOOK_TITLE=Menadžment ljudskih potencijala
#BOOK_ID=mlp
# Mapa s datotekama knjige (.pdf s tekstualnim slojem, .md ili .txt):
#KNOWLEDGE_DIR=knowledge
# Rezervna podjela (kad se poglavlja ne prepoznaju): stranica po odjeljku:
#PAGES_PER_SECTION=6
# Odjeljci kraći od ovoliko znakova spajaju se s prethodnim:
#MIN_SECTION_CHARS=400

# --- RAG parametri -------------------------------------------------------------
# Zadane vrijednosti su u kodu (lib/config.ts). Postavi ENV samo ako želiš nadjačati.
#
# Broj isječaka koji se dohvaća (zadano 12):
#RAG_TOP_K=12
# Prag kosinusne sličnosti 0–1; niže = veći recall (zadano 0.30):
#RAG_SCORE_THRESHOLD=0.30
# Leksički (Postgres FTS) kanal — hibridni dohvat; ključan za stručne pojmove
# i imena (1 = uključeno, 0 = isključeno; zadano uključeno):
#RAG_FTS_FALLBACK=1
# Proračun znakova za kontekst koji se šalje modelu (~4 znaka ≈ 1 token; zadano 12000):
#RAG_CONTEXT_CHAR_BUDGET=12000
# Reranking: brzi LLM (Haiku) presloži širi skup kandidata po relevantnosti — bira
# pravi odjeljak knjige među mnogo sličnih. 1 = uključeno (zadano), 0 = isključeno:
#RAG_RERANK=1
# Broj kandidata koji se rerankaju (zadano 40):
#RAG_RERANK_CANDIDATES=40
# Model za reranking (zadano claude-haiku-4-5 — brz/jeftin):
#RERANK_MODEL=claude-haiku-4-5

# --- Ingestija -----------------------------------------------------------------
# Tajna kojom se autorizira /api/ingest (i sol za anonimizaciju logova).
# Generirajte npr.: openssl rand -hex 32
INGEST_SECRET=

# Parametri chunkinga (u "tokenima"; interno ~4 znaka po tokenu)
MAX_CHUNK_TOKENS=300
CHUNK_OVERLAP=50

# Zaštita PDF-koraka (da pokvaren/golem PDF ne zaglavi ingest):
# Timeout za parsiranje knjige u ms (zadano 120000 — knjige su velike):
#PDF_PARSE_TIMEOUT_MS=120000
# Najveća dopuštena veličina PDF-a u bajtovima (zadano 104857600 = 100 MB):
#MAX_PDF_BYTES=104857600

# --- Općenito --------------------------------------------------------------------
LANG=hr

# Produkcijska adresa aplikacije (za kanonske/OG poveznice u <head>). Na Vercelu se
# inače koristi automatski VERCEL_URL; postavi za stabilnu/custom domenu.
NEXT_PUBLIC_SITE_URL=https://hr-asistent.vercel.app
